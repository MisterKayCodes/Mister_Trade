# Mister Trade — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
DB_PATH=mister_trade.db

# ---------------------------------------------------------------
# Telegram (needed from Phase 3)
# ---------------------------------------------------------------
# Your bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Channel where signals are posted (e.g. @mrsignals or -1001234567890)
CHANNEL_ID=@your_channel_here

# Comma-separated Telegram user IDs allowed to use /admin
ADMIN_IDS=123456789

# ---------------------------------------------------------------
# Engine
# ---------------------------------------------------------------
# Price check interval in seconds (default 30)
CYCLE_INTERVAL=30
